generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTHENTICATION ====================

enum UserRole {
  ADMIN
  SALES
  CUSTOMER
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  password           String       // Hashed password
  name               String
  role               UserRole     @default(SALES)
  isActive           Boolean      @default(true)
  customerCompanyId  String?
  customerContactId  String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  lastLoginAt        DateTime?

  sessions           Session[]
  customerCompany    SalesCompany? @relation("CustomerCompanyUsers", fields: [customerCompanyId], references: [id], onDelete: SetNull)
  customerContact    SalesContact? @relation("CustomerContactUsers", fields: [customerContactId], references: [id], onDelete: SetNull)
  createdProposals   SalesProposal[] @relation("SalesProposalCreatedBy")

  @@index([email])
  @@index([role])
  @@index([customerCompanyId])
  @@index([customerContactId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ==================== CONTACT FORM ====================

model Lead {
  id           String   @id @default(cuid())
  businessName String?
  email        String
  message      String
  createdAt    DateTime @default(now())
}

// ==================== OUTREACH MODULE ====================

enum OutreachLeadStage {
  NEW
  CONTACTED
  REPLIED
  BOOKED
  WON
  LOST
}

model OutreachLead {
  id               String            @id @default(cuid())
  company          String
  contactName      String
  role             String?
  email            String?           @unique
  phone            String?
  website          String?
  city             String?
  industry         String?
  stage            OutreachLeadStage @default(NEW)
  score            Int               @default(50)
  tags             String[]          @default([])
  notes            String?
  ownerUserId      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastTouchAt      DateTime?
  lastActivity     String?
  nextStep         String?
  doNotContact     Boolean           @default(false)
  unsubscribedAt   DateTime?
  
  enrollments      OutreachEnrollment[]
  messages         OutreachMessage[]
  replies          OutreachReply[]

  @@index([email])
  @@index([stage])
  @@index([doNotContact])
}

enum CampaignChannel {
  EMAIL
  LINKEDIN
  SMS
}

enum CampaignStatus {
  RUNNING
  PAUSED
}

model OutreachCampaign {
  id                    String          @id @default(cuid())
  name                  String
  channel               CampaignChannel @default(EMAIL)
  status                CampaignStatus  @default(PAUSED)
  dailyLimit            Int             @default(30)
  fromMailbox           String
  audienceIndustry      String?
  audienceGeoContains   String?
  audienceMinScore      Int?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  steps                 OutreachCampaignStep[]
  enrollments           OutreachEnrollment[]
  messages              OutreachMessage[]
  replies               OutreachReply[]

  @@index([status])
}

model OutreachCampaignStep {
  id              String   @id @default(cuid())
  campaignId      String
  stepIndex       Int
  dayOffset       Int
  subjectTemplate String
  bodyTemplate    String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  campaign        OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  messages        OutreachMessage[]

  @@unique([campaignId, stepIndex])
  @@index([campaignId])
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  STOPPED
}

model OutreachEnrollment {
  id             String           @id @default(cuid())
  leadId         String
  campaignId     String
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stoppedReason  String?
  
  lead           OutreachLead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign       OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([leadId, campaignId])
  @@index([status])
  @@index([leadId])
  @@index([campaignId])
}

enum MessageStatus {
  SCHEDULED
  SENT
  DELIVERED
  FAILED
  REPLIED
  CANCELED
}

model OutreachMessage {
  id                  String        @id @default(cuid())
  leadId              String
  campaignId          String
  stepId              String
  scheduledFor        DateTime
  sentAt              DateTime?
  providerMessageId   String?
  status              MessageStatus @default(SCHEDULED)
  subjectRendered     String
  bodyRendered        String        @db.Text
  deliveredAt         DateTime?
  error               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  
  lead                OutreachLead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign            OutreachCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  step                OutreachCampaignStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  replies             OutreachReply[]

  @@index([scheduledFor, status])
  @@index([leadId])
  @@index([campaignId])
  @@index([status])
}

enum ReplySentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model OutreachReply {
  id          String         @id @default(cuid())
  leadId      String
  campaignId  String
  messageId   String?
  receivedAt  DateTime
  fromEmail   String
  subject     String
  body        String         @db.Text
  sentiment   ReplySentiment @default(NEUTRAL)
  raw         Json?
  createdAt   DateTime       @default(now())
  
  lead        OutreachLead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign    OutreachCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  message     OutreachMessage?  @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([campaignId])
  @@index([receivedAt])
}

model OutreachUnsubscribe {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

// ==================== SALES MACHINE (INTERNAL) ====================

enum SalesSourceType {
  GOOGLE_PLACES
  CSV_IMPORT
  MANUAL
  OTHER
}

enum SalesOutreachStatus {
  DRAFT
  READY
  APPROVED
  SENT
  REPLIED
  BOUNCED
  STOPPED
}

enum SalesOpportunityStage {
  NEW
  QUALIFIED
  PROPOSAL_DRAFTED
  PROPOSAL_SENT
  WON
  LOST
}

enum SalesEquipmentType {
  CONDENSER
  AIR_HANDLER
  FURNACE
  HEAT_PUMP
  COIL
  PACKAGE_UNIT
  THERMOSTAT
  IAQ
  OTHER
}

enum SalesCatalogPricingMode {
  FIXED_SELL_PRICE
  COST_PLUS_MARGIN
}

enum SalesProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
}

enum SalesProposalTier {
  GOOD
  BETTER
  BEST
}

enum SalesProposalAddonType {
  ADDON
  DISCOUNT
  REBATE
}

enum SalesProposalEventType {
  DRAFT_CREATED
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EMAIL_SENT
  FOLLOW_UP_SENT
  STATUS_CHANGED
}

model SalesCompany {
  id                  String             @id @default(cuid())
  slug                String             @unique
  name                String
  website             String?
  phone               String?
  city                String?
  state               String?
  country             String             @default("US")
  placeId             String?            @unique
  category            String?
  rating              Float?
  reviewCount         Int?
  sourceType          SalesSourceType    @default(OTHER)
  sourceRef           String?
  discoveredAt        DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  isQualified         Boolean            @default(false)
  disqualifiedReason  String?
  contacts            SalesContact[]
  audits              SalesWebsiteAudit[]
  scores              SalesLeadScore[]
  outreachMessages    SalesOutreachMessage[]
  customerUsers       User[]              @relation("CustomerCompanyUsers")
  opportunities       SalesOpportunity[]
  proposals           SalesProposal[]

  @@index([slug])
  @@index([name])
  @@index([city, state])
  @@index([isQualified])
  @@index([discoveredAt])
}

model SalesContact {
  id          String       @id @default(cuid())
  companyId   String
  fullName    String?
  role        String?
  email       String?
  phone       String?
  isPrimary   Boolean      @default(false)
  source      String?
  confidence  Int          @default(50)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     SalesCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages    SalesOutreachMessage[]
  customerUsers User[]     @relation("CustomerContactUsers")
  opportunities SalesOpportunity[]
  proposals   SalesProposal[]

  @@index([companyId])
  @@index([email])
}

model SalesWebsiteAudit {
  id                           String       @id @default(cuid())
  companyId                    String
  hasOnlineBooking             Boolean      @default(false)
  hasEmergencyCta              Boolean      @default(false)
  hasMissedCallTextBack        Boolean      @default(false)
  hasFastResponsePromise       Boolean      @default(false)
  hasFinancingCta              Boolean      @default(false)
  hasAfterHoursCapture         Boolean      @default(false)
  hasChatOrTextOption          Boolean      @default(false)
  hasStrongReviewProcess       Boolean      @default(false)
  hasClearEstimateFlow         Boolean      @default(false)
  mobilePerformanceScore       Int?
  notes                        String?      @db.Text
  auditVersion                 String       @default("v1")
  auditedUrl                   String?
  crawlStatus                  String       @default("pending")
  crawlError                   String?
  auditedAt                    DateTime?
  detectedTools                String[]     @default([])
  createdAt                    DateTime     @default(now())
  company                      SalesCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  evidence                     SalesAuditEvidence[]

  @@index([companyId])
  @@index([createdAt])
}

model SalesAuditEvidence {
  id            String            @id @default(cuid())
  auditId       String
  code          String
  label         String
  observed      Boolean
  severity      String            @default("medium")
  confidence    Int               @default(80)
  sourceUrl     String?
  snippet       String?           @db.Text
  screenshotUrl String?
  createdAt     DateTime          @default(now())
  audit         SalesWebsiteAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([code])
}

model SalesLeadScore {
  id                String               @id @default(cuid())
  companyId         String
  icpFit            Int
  revenuePotential  Int
  painSignals       Int
  contactability    Int
  disqualifiers     Int
  totalScore        Int
  explanation       String               @db.Text
  buyingLikelihood  Int                  @default(0)
  dealThesis        String?              @db.Text
  thesisConfidence  Int                  @default(0)
  modelVersion      String               @default("v1")
  createdAt         DateTime             @default(now())
  company           SalesCompany         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  evidence          SalesScoreEvidence[]

  @@index([companyId])
  @@index([totalScore])
  @@index([buyingLikelihood])
  @@index([createdAt])
}

model SalesScoreEvidence {
  id          String         @id @default(cuid())
  scoreId     String
  code        String
  label       String
  points      Int
  detail      String?
  createdAt   DateTime       @default(now())
  score       SalesLeadScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)

  @@index([scoreId])
  @@index([code])
}

model SalesKnowledgeDocument {
  id          String               @id @default(cuid())
  title       String
  sourceType  String               @default("internal")
  text        String               @db.Text
  tags        String[]             @default([])
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  chunks      SalesKnowledgeChunk[]

  @@index([isActive])
  @@index([createdAt])
}

model SalesKnowledgeChunk {
  id            String                 @id @default(cuid())
  documentId    String
  chunkIndex    Int
  content       String                 @db.Text
  keywords      String[]               @default([])
  createdAt     DateTime               @default(now())
  document      SalesKnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([chunkIndex])
}

model SalesOutreachMessage {
  id                 String              @id @default(cuid())
  companyId          String
  contactId          String?
  status             SalesOutreachStatus @default(DRAFT)
  subject            String
  body               String              @db.Text
  personalization    Json?
  retrievedChunkIds  String[]            @default([])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sentAt             DateTime?
  repliedAt          DateTime?
  bounceType         String?
  bounceReason       String?
  complianceSnapshot Json?
  replyIntent        String?
  replySnippet       String?             @db.Text
  company            SalesCompany        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact            SalesContact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([replyIntent])
}

model SalesOpportunity {
  id                 String                @id @default(cuid())
  companyId          String
  contactId          String?
  title              String
  stage              SalesOpportunityStage @default(NEW)
  estimatedJobValue  Decimal?              @db.Decimal(12, 2)
  targetInstallDate  DateTime?
  notes              String?               @db.Text
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  company            SalesCompany          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact            SalesContact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  proposals          SalesProposal[]

  @@index([companyId])
  @@index([contactId])
  @@index([stage])
  @@index([createdAt])
}

model SalesHvacCatalogItem {
  id                String                  @id @default(cuid())
  equipmentType     SalesEquipmentType
  brand             String
  modelNumber       String
  sizeTonnage       String?
  efficiencyRating  String?
  cost              Decimal                 @db.Decimal(12, 2)
  pricingMode       SalesCatalogPricingMode @default(COST_PLUS_MARGIN)
  sellPrice         Decimal?                @db.Decimal(12, 2)
  marginPercent     Float?
  description       String?                 @db.Text
  imageUrl          String?
  brochureUrl       String?
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  proposalOptions   SalesProposalOption[]

  @@index([equipmentType])
  @@index([brand])
  @@index([isActive])
  @@unique([brand, modelNumber])
}

model SalesProposal {
  id                String              @id @default(cuid())
  opportunityId     String
  companyId         String
  contactId         String?
  publicToken       String              @unique
  status            SalesProposalStatus @default(DRAFT)
  title             String
  notes             String?             @db.Text
  companyProposalFooter String?         @db.Text
  proposalDisclaimer String?            @db.Text
  version           Int                 @default(1)
  selectedOptionId  String?
  createdByUserId   String?
  sentAt            DateTime?
  viewedAt          DateTime?
  acceptedAt        DateTime?
  declinedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  opportunity       SalesOpportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  company           SalesCompany        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact           SalesContact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdBy         User?               @relation("SalesProposalCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  selectedOption    SalesProposalOption? @relation("SalesProposalSelectedOption", fields: [selectedOptionId], references: [id], onDelete: SetNull)
  options           SalesProposalOption[] @relation("SalesProposalOptions")
  events            SalesProposalEvent[]

  @@index([opportunityId])
  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([createdAt])
}

model SalesProposalOption {
  id                      String             @id @default(cuid())
  proposalId              String
  tier                    SalesProposalTier
  title                   String
  summary                 String?            @db.Text
  equipmentItemId         String?
  equipmentSnapshot       Json?
  warrantyLabel           String?
  financingApr            Float?
  financingMonths         Int?
  monthlyPaymentEstimate  Decimal?           @db.Decimal(12, 2)
  equipmentCost           Decimal            @db.Decimal(12, 2)
  laborCost               Decimal            @db.Decimal(12, 2)
  permitFee               Decimal            @default(0) @db.Decimal(12, 2)
  taxRatePercent          Float              @default(0)
  taxAmount               Decimal            @default(0) @db.Decimal(12, 2)
  preTaxCustomerPrice     Decimal            @default(0) @db.Decimal(12, 2)
  addonsTotal             Decimal            @db.Decimal(12, 2)
  discountsTotal          Decimal            @db.Decimal(12, 2)
  rebatesTotal            Decimal            @db.Decimal(12, 2)
  totalCost               Decimal            @db.Decimal(12, 2)
  grossMarginAmount       Decimal            @db.Decimal(12, 2)
  grossMarginPercent      Float
  finalCustomerPrice      Decimal            @db.Decimal(12, 2)
  sortOrder               Int                @default(0)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  proposal                SalesProposal      @relation("SalesProposalOptions", fields: [proposalId], references: [id], onDelete: Cascade)
  equipmentItem           SalesHvacCatalogItem? @relation(fields: [equipmentItemId], references: [id], onDelete: SetNull)
  selectedByProposal      SalesProposal[]    @relation("SalesProposalSelectedOption")
  addonLines              SalesProposalAddonLine[]

  @@unique([proposalId, tier])
  @@index([proposalId])
  @@index([equipmentItemId])
}

model SalesProposalAddonLine {
  id         String                @id @default(cuid())
  optionId   String
  type       SalesProposalAddonType
  label      String
  amount     Decimal               @db.Decimal(12, 2)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  option     SalesProposalOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
  @@index([type])
}

model SalesProposalEvent {
  id         String                 @id @default(cuid())
  proposalId String
  eventType  SalesProposalEventType
  metadata   Json?
  occurredAt DateTime               @default(now())
  proposal   SalesProposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([eventType])
  @@index([occurredAt])
}

model SalesProposalSettings {
  id                    String   @id @default("default")
  defaultLaborCost      Decimal  @db.Decimal(12, 2)
  defaultFinancingApr   Float
  defaultFinancingMonths Int
  defaultWarrantyGood   String
  defaultWarrantyBetter String
  defaultWarrantyBest   String
  permitFeeDefault      Decimal  @db.Decimal(12, 2)
  taxRatePercent        Float
  companyProposalFooter String   @db.Text
  proposalDisclaimer    String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
